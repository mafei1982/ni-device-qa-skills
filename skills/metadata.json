    },
    {
      "name": "dcpower_c_api_lcr",
      "type": "doc",
      "subtype": "programming_api",
      "device": "dcpower_c_api",
      "description": "NI-DCPower C API — LCR & Impedance: LCR measurement attributes (AC stimulus, AC dither, current/voltage range, aperture time, frequency, impedance range, source delay), LCR compensation attributes (open/short/load compensation, measured load reactance/resistance, DC bias), and instrument mode.",
      "language": "c",
      "category": "dcpower",
      "api_section": "lcr"
    },
    {
      "name": "dcpower_c_api_measure",
      "type": "doc",
      "subtype": "programming_api",
      "device": "dcpower_c_api",
      "description": "NI-DCPower C API — Measure: Measurement attributes including autorange, aperture time, aperture time units and auto-mode, measure when, measure record length/delta time, DC noise rejection, power line frequency, sense (local/remote), samples to average, and measure trigger configuration.",
      "language": "c",
      "category": "dcpower",
      "api_section": "measure"
    },
    {
      "name": "dcpower_c_api_source",
      "type": "doc",
      "subtype": "programming_api",
      "device": "dcpower_c_api",
      "description": "NI-DCPower C API — Source & Triggers (Attributes): Source attributes (voltage/current level, limits, compliance, output function, output resistance, source mode, source delay, conduction voltage, transient response, overranging), constant power/resistance attributes, DC voltage/current attributes, pulse voltage/current attributes, output cutoff, trigger attributes (measure/pulse/sequence advance/shutdown/source/start triggers, digital edge configuration), and Supported Attributes by Device tables.",
      "language": "c",
      "category": "dcpower",
      "api_section": "source"
    },
    {
      "name": "dcpower_c_api_functions",
      "type": "doc",
      "subtype": "programming_api",
      "device": "dcpower_c_api",
      "description": "NI-DCPower C API — Functions Reference: All C function signatures and parameters including Calibration (niDCPower_ChangeExtCalPassword, self-calibrate), LCR Compensation functions, Control (Abort, Commit, Initiate), Initialize/Close, Measure functions (ConfigureApertureTime, FetchMultiple, Measure, MeasureMultiple), Query functions (QueryLatchedOutputCutoffState, QueryMaxCurrentLimit, QueryMaxVoltageLevel, QueryOutputState), Set/Get Attribute, Source functions (ConfigureSourceMode, CreateAdvancedSequenceStep, SetSequence), Trigger/Event functions (ConfigureTrigger, SendSoftwareEdgeTrigger, ExportSignal, WaitForEvent), Utility, IVI, Locking, and obsolete/unsupported functions.",
      "language": "c",
      "category": "dcpower",
      "api_section": "functions"
